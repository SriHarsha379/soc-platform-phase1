# ============================================================
# SOC Platform Phase 1 - Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================================

# --- General ---
COMPOSE_PROJECT_NAME=soc-platform

# --- Zabbix ---
ZABBIX_DB_HOST=zabbix-db
ZABBIX_DB_PORT=5432
ZABBIX_DB_NAME=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=zabbix_secure_password

POSTGRES_USER=zabbix
POSTGRES_PASSWORD=zabbix_secure_password
POSTGRES_DB=zabbix

ZABBIX_SERVER_HOST=zabbix-server
ZABBIX_SERVER_PORT=10051

# Zabbix Web UI
ZBX_SERVER_HOST=zabbix-server
PHP_TZ=UTC

# --- Wazuh ---
WAZUH_MANAGER_HOST=wazuh-manager
WAZUH_API_PORT=55000
WAZUH_API_USER=wazuh-wui
WAZUH_API_PASSWORD=wazuh_api_secure_password

WAZUH_CLUSTER_NAME=wazuh
WAZUH_CLUSTER_KEY=c98b62a9b0469957664d3c2329c50294
WAZUH_CLUSTER_NODE_NAME=master-node

# --- Elasticsearch ---
ELASTIC_VERSION=8.11.0
ELASTIC_HOST=elasticsearch
ELASTIC_PORT=9200
ELASTIC_USERNAME=elastic
ELASTIC_PASSWORD=elastic_secure_password

ES_JAVA_OPTS=-Xms512m -Xmx512m
ELASTICSEARCH_HEAP_SIZE=512m

# --- Kibana ---
KIBANA_HOST=kibana
KIBANA_PORT=5601
KIBANA_ENCRYPTION_KEY=<run: openssl rand -hex 16>

# --- Alerting (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_FROM=soc-alerts@yourdomain.com
ALERT_RECIPIENTS=security-team@yourdomain.com,soc-manager@yourdomain.com

# --- Alert Thresholds ---
CPU_ALERT_THRESHOLD=85
MEMORY_ALERT_THRESHOLD=90
DISK_ALERT_THRESHOLD=85
FAILED_LOGIN_THRESHOLD=5

# --- Networking ---
SOC_NETWORK_SUBNET=172.20.0.0/16

# --- TLS/SSL ---
# Set to 'true' to enable TLS (requires cert files in config/certs/)
TLS_ENABLED=false

# ============================================================
# Application Stack (docker-compose.app.yml)
# ============================================================

# --- SOC Application Database (PostgreSQL) ---
SOC_DB_USER=soc_user
SOC_DB_PASSWORD=soc_password
SOC_DB_NAME=soc_db

# --- Application JWT ---
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=8h

# --- Elasticsearch index for log queries ---
ELASTIC_INDEX=wazuh-alerts-*

# --- Nginx public port ---
APP_PORT=80

# --- SOAR (Telegram – optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
