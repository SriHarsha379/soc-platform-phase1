# SOC AI Service – Baseline configuration
# Copy to .env and adjust for your environment

# Event baselines – mean and standard deviation of normal behaviour
BASELINE_LOGIN_MEAN=2
BASELINE_LOGIN_STD=1.5
BASELINE_CPU_MEAN=40
BASELINE_CPU_STD=20
BASELINE_TRAFFIC_MEAN=100
BASELINE_TRAFFIC_STD=50

# Sigma threshold for anomaly flag (default: 2σ)
ANOMALY_SIGMA_THRESHOLD=2.0
