PORT=4000
NODE_ENV=development
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=8h
DATABASE_URL=file:./prisma/dev.db
ELASTIC_URL=http://localhost:9200
ELASTIC_INDEX=wazuh-alerts-*
# Optional when Elasticsearch auth is enabled
# ELASTIC_USERNAME=elastic
# ELASTIC_PASSWORD=your_password
# Correlation rule thresholds (optional – defaults shown)
CORRELATION_BRUTE_FORCE_THRESHOLD=5
CORRELATION_BRUTE_FORCE_WINDOW_MIN=10
CORRELATION_TRAFFIC_SPIKE_THRESHOLD=500
CORRELATION_TRAFFIC_SPIKE_WINDOW_MIN=5
