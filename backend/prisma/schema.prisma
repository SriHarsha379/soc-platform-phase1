generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("analyst")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Alert {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  severity    String
  status      String   @default("open")
  source      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LogMeta {
  id          Int      @id @default(autoincrement())
  logType     String
  source      String
  severity    String?
  referenceId String?
  timestamp   DateTime
  createdAt   DateTime @default(now())
}

model Incident {
  id           Int      @id @default(autoincrement())
  title        String
  description  String
  severity     String   // low | medium | high | critical
  ruleType     String   // brute_force | traffic_spike | custom
  status       String   @default("open") // open | investigating | resolved
  sourceIp     String?
  affectedHost String?
  eventCount   Int      @default(1)
  riskScore    Int?     // 0–100 AI-derived risk score (null if AI service unavailable)
  aiReason     String?  // Human-readable explanation from the AI service
  firstSeen    DateTime
  lastSeen     DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
