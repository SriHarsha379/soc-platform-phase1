{
  "_comment": "Time-based anomalies: access outside business hours (09:00-18:00 Mon-Fri) or on weekends",
  "description": "Detects unauthorized or suspicious access patterns outside normal business hours",
  "severity": "medium",
  "mitre_tactic": "Initial Access",
  "mitre_technique": "T1078.004",

  "_note_painless_script": "The off-hours Painless script is referenced once via a top-level filter agg; sub-aggs run inside that single filter to avoid duplication. For production use, register this as a stored script via PUT /_scripts/soc-off-hours-filter.",

  "query": {
    "size": 0,
    "query": {
      "bool": {
        "must": [
          {
            "range": {
              "@timestamp": {
                "gte": "now-24h",
                "lte": "now"
              }
            }
          },
          {
            "bool": {
              "should": [
                { "match": { "event.category": "authentication" } },
                { "match": { "event.outcome": "success" } },
                { "terms": { "rule.id": ["5715", "5718", "2501", "2502", "100001"] } }
              ],
              "minimum_should_match": 1
            }
          }
        ],
        "filter": [
          { "exists": { "field": "user.name" } }
        ]
      }
    },
    "aggs": {
      "off_hours_filter": {
        "_comment": "Single Painless filter applied once; all sub-aggs run inside it to avoid script duplication",
        "filter": {
          "script": {
            "script": {
              "id": "soc-off-hours-filter"
            }
          }
        },
        "aggs": {
          "by_hour": {
            "date_histogram": {
              "field": "@timestamp",
              "calendar_interval": "1h",
              "time_zone": "UTC"
            },
            "aggs": {
              "by_user": {
                "terms": { "field": "user.name", "size": 20 }
              },
              "by_host": {
                "terms": { "field": "host.name", "size": 20 }
              }
            }
          },
          "top_users": {
            "terms": {
              "field": "user.name",
              "size": 50,
              "order": { "_count": "desc" }
            },
            "aggs": {
              "hosts_accessed": {
                "terms": { "field": "host.name", "size": 10 }
              },
              "time_distribution": {
                "date_histogram": {
                  "field": "@timestamp",
                  "calendar_interval": "1h"
                }
              }
            }
          }
        }
      },
      "new_user_access": {
        "_comment": "Users who appeared in last 24h; correlate with off_hours_filter for first-time off-hours access",
        "filter": {
          "range": {
            "@timestamp": { "gte": "now-24h" }
          }
        },
        "aggs": {
          "first_time_users": {
            "terms": { "field": "user.name", "size": 50, "min_doc_count": 1 }
          }
        }
      }
    }
  },

  "stored_script_registration": {
    "_comment": "Register this Painless script in ES before running the query above (required for stored script reference)",
    "api": "PUT /_scripts/soc-off-hours-filter",
    "body": {
      "script": {
        "lang": "painless",
        "source": "ZonedDateTime dt = doc['@timestamp'].value; int hour = dt.getHour(); int dow = dt.getDayOfWeek().getValue(); boolean isWeekend = dow == 6 || dow == 7; boolean isOffHours = hour < 9 || hour >= 18; return isWeekend || isOffHours;"
      }
    }
  },

  "business_hours_config": {
    "timezone": "UTC",
    "start_hour": 9,
    "end_hour": 18,
    "working_days": [1, 2, 3, 4, 5],
    "weekend_days": [6, 7]
  },

  "alert_condition": {
    "min_off_hours_events": 3,
    "window": "24h",
    "field": "user.name",
    "new_user_flag": true
  },

  "alert_action": {
    "create_alert": true,
    "tag_as": "off-hours-access-detected",
    "severity": "medium",
    "notify_soc": true,
    "playbook": "docs/playbooks/off-hours-access-response.md"
  }
}
