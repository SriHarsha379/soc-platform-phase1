# SOC SOAR Service – environment configuration
# Copy to .env and fill in your values

# Database path for execution audit log (default works inside Docker)
SOAR_DB_PATH=/data/soar.db

# ── Email (SMTP) ───────────────────────────────────────────────────────────────
# If not set, email actions are simulated (logged but not sent)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-smtp-app-password
SMTP_FROM=soc-soar@yourdomain.com
ALERT_RECIPIENTS=security-team@yourdomain.com

# ── Telegram ───────────────────────────────────────────────────────────────────
# If not set, Telegram actions are simulated
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
